# ============ World ID 4.0 (Developer Portal) ============
# Production (from Dashboard → World ID 4.0):
#   APP ID (Legacy) → APP_ID
#   RP ID           → RP_ID
#   Signer key      → RP_SIGNING_KEY (Configure Signer Key → download private key)
APP_ID=app_fc0da8b52c48aee3c0fd52657cac8474
RP_ID=rp_8e802254f0934bb5
RP_SIGNING_KEY=0x...your_downloaded_signer_private_key...

# Staging (required for simulator at https://simulator.worldcoin.org)
# The simulator ONLY accepts your STAGING app — not your production app.
# In Developer Portal: switch to your Staging app (different from Production!), open World ID 4.0,
# copy that app's APP ID (Legacy) and RP ID here. Same RP_SIGNING_KEY often works for both.
# APP_ID_STAGING=app_staging_xxxxxxxx
# RP_ID_STAGING=rp_xxxxxxxx

# Optional: Custom action and signal for proof requests
# WORLD_ID_ACTION=cre-ancile-stealth-verification
# WORLD_ID_SIGNAL=0x8a52a28861990cd173F3Ef8FD20caC84BFA4236d

# ============ Wallets & RPC ============
# BOB_PRIVATE_KEY=0x...
# ALICE_PRIVATE_KEY=0x...
# BASE_SEPOLIA_RPC_URL=https://...   (optional override; if you get 429 rate-limit, set to public RPC e.g. https://sepolia.base.org)
